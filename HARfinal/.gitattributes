# Auto-detect text files and normalize line endings
* text=auto

# Source code — always LF
*.c text eol=lf
*.h text eol=lf
*.s text eol=lf
*.S text eol=lf
*.ld text eol=lf
*.cmake text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files — do not modify
*.a binary
*.o binary
*.elf binary
*.bin binary
*.hex binary
*.zip binary
*.png binary
*.jpg binary
*.pdf binary
